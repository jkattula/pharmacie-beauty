# Database Connection (Supabase PostgreSQL)
# Get this from your Supabase project dashboard > Settings > Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# OpenAI API Key (for AI-powered search)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Optional: Supabase Configuration (for future features like storage)
# NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."

# Google Analytics 4 Measurement ID (optional)
# Get this from https://analytics.google.com → Admin → Data Streams
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Microsoft Clarity Project ID (optional)
# Get this from https://clarity.microsoft.com → Settings → Setup
# NEXT_PUBLIC_CLARITY_ID="xxxxxxxxxx"
